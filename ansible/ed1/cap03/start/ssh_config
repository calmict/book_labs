# Chapter 3 — your SSH config. Use it with:  ssh -F start/ssh_config <host>
#
# The bastion entry is written for you as a worked example. Complete the two
# TODOs below.

Host bastion
    HostName 127.0.0.1
    Port 2223
    User root
    IdentityFile /tmp/cap03-lab/key
    # lab niceties: the containers are throwaway, so we skip host-key prompts.
    # In production you would NOT do this (see Phase 6).
    StrictHostKeyChecking no
    UserKnownHostsFile /dev/null
    LogLevel ERROR

