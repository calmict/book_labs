# book_labs — .gitignore
# Repository di esercizi: Kubernetes, Ansible, Terraform/OpenTofu.
# Si committano start/ e solution/ (codice e manifest). Si ignorano stato,
# artefatti locali, segreti e rumore di sistema.

# --- Terraform / OpenTofu ---
# Stato e directory di lavoro: MAI committare.
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
# Variabili che possono contenere segreti.
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
.terraform.lock.hcl

# --- Ansible ---
*.retry
# Vault e inventory con dati sensibili (se mai presenti negli esercizi).
*vault*.yml
!*vault*example*.yml

# --- Kubernetes ---
# Kubeconfig locali: mai committare credenziali di cluster.
kubeconfig
*.kubeconfig
kube.config

# --- Segreti generici ---
*.pem
*.key
*.crt
.env
.env.*
!.env.example
secrets.*
*.secret

# --- Sistema operativo ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editor / IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.\#*
\#*\#

# --- Log e temporanei ---
*.log
*.tmp
tmp/
