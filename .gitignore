# book_labs — .gitignore
# Exercise repository: Kubernetes, Ansible, Terraform/OpenTofu.
# start/ and solution/ (code and manifests) are committed. Local state,
# build artifacts, secrets and OS noise are ignored.

# --- Terraform / OpenTofu ---
# State and working directories: NEVER commit.
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
# Variable files that may contain secrets.
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
.terraform.lock.hcl

# --- Ansible ---
*.retry
# Downloaded Galaxy collections (regenerated from requirements.yml, never commit).
ansible_collections/
# Vault and inventory files with sensitive data (if ever present in exercises).
*vault*.yml
!*vault*example*.yml
# Exception: solution vault files are demo-encrypted with a passphrase printed
# in the chapter README (never a real secret), and are meant to be committed so
# the exercise ships complete. Real vaults anywhere else stay ignored.
!ansible/**/solution/**/vault.yml

# --- Python ---
# Byte-compiled files from running the exercise scripts.
__pycache__/
*.py[cod]

# --- Kubernetes ---
# Local kubeconfig files: never commit cluster credentials.
kubeconfig
*.kubeconfig
kube.config

# --- Generic secrets ---
*.pem
*.key
*.crt
.env
.env.*
!.env.example
secrets.*
*.secret

# --- Operating system ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- Editors / IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~
.\#*
\#*\#

# --- Logs and temporary files ---
*.log
*.tmp
tmp/
