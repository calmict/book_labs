# GALLERY — read, do not execute (the .example extension keeps tofu away).
#
# The manual's extended example 9.5: network and server on AWS. Wear
# today's glasses: arguments go in, attributes come out, and at the first
# apply the unknown crosses the whole graph along the reference edges.

# Credentials from outside, as always (chapter 8).
provider "aws" {
  region = "eu-south-1"
}

resource "aws_vpc" "main" {
  cidr_block = "10.0.0.0/16" # argument: input you impose
}

resource "aws_subnet" "app" {
  vpc_id            = aws_vpc.main.id # ATTRIBUTE of the vpc -> input here: an edge
  cidr_block        = "10.0.1.0/24"
  availability_zone = "eu-south-1a"
}

resource "aws_instance" "web" {
  ami           = "ami-0abcdef1234567890"
  instance_type = "t3.micro"
  subnet_id     = aws_subnet.app.id # the subnet's id travels on

  tags = {
    Name = "web-01"
  }
}

# At the first apply, every .id above is (known after apply): three
# resources, two edges, and the declared unknown flowing vpc -> subnet ->
# instance — exactly what you watched in your dossier, at cloud scale.
output "web_private_ip" {
  value = aws_instance.web.private_ip # attribute: discovered at birth
}
